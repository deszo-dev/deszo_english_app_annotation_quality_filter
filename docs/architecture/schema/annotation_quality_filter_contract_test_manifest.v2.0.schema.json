{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schema/annotation_quality_filter_contract_test_manifest.v2.0.schema.json",
  "title": "AnnotationQualityFilter Contract Test Manifest v2.0",
  "description": "Automation-ready non-registry contract tests for API, CLI, scoring boundaries, determinism, limits, and compatibility.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "tests"
  ],
  "properties": {
    "manifest_version": {
      "const": "annotation_quality_filter_contract_test_manifest.v2.0"
    },
    "description": {
      "type": "string"
    },
    "tests": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/Test"
      }
    }
  },
  "$defs": {
    "Test": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "priority",
        "area",
        "purpose",
        "requirement_reference",
        "input_fixture_or_inline",
        "config_fixture_or_inline",
        "execution_modes",
        "expected_result",
        "assertions",
        "normalization"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^CT-[A-Z0-9-]+$"
        },
        "priority": {
          "enum": [
            "P0",
            "P1",
            "P2"
          ]
        },
        "area": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "requirement_reference": {
          "type": "string"
        },
        "input_fixture_or_inline": {
          "type": "string"
        },
        "config_fixture_or_inline": {
          "type": "string"
        },
        "execution_modes": {
          "type": "array",
          "items": {
            "enum": [
              "api",
              "cli",
              "unit"
            ]
          },
          "minItems": 1
        },
        "expected_result": {
          "type": "string"
        },
        "deterministic_generation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "kind": {
              "enum": [
                "fixture_mutation",
                "generated_json_bytes",
                "generated_json_depth",
                "aggregator_unit_case",
                "filesystem_precondition",
                "api_runtime_object",
                "none"
              ]
            },
            "recipe": {
              "type": "string"
            },
            "base_fixture": {
              "type": [
                "string",
                "null"
              ]
            },
            "exact_size_bytes": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            },
            "exact_depth": {
              "type": [
                "integer",
                "null"
              ],
              "minimum": 0
            }
          }
        },
        "assertions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "normalization": {
          "type": "string"
        }
      }
    }
  }
}
