{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deszo.local/schema/annotation_quality_filter_config.v2.0.schema.json",
  "title": "AnnotationQualityUserConfigOverride v2.0",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "thresholds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "high": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.8
        },
        "medium": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.6
        },
        "low": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.3
        }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "structural": {
          "type": "number",
          "minimum": 0,
          "default": 0.3
        },
        "dependency": {
          "type": "number",
          "minimum": 0,
          "default": 0.35
        },
        "morphology": {
          "type": "number",
          "minimum": 0,
          "default": 0.15
        },
        "sentence": {
          "type": "number",
          "minimum": 0,
          "default": 0.1
        },
        "distribution": {
          "type": "number",
          "minimum": 0,
          "default": 0.1
        }
      }
    },
    "limits": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "max_sentence_length": {
          "type": "integer",
          "minimum": 1,
          "default": 60
        },
        "long_sentence_soft": {
          "type": "integer",
          "minimum": 1,
          "default": 40
        },
        "long_sentence_hard": {
          "type": "integer",
          "minimum": 1,
          "default": 80
        },
        "max_conj_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.3
        },
        "severe_conj_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "max_noun_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.6
        },
        "max_deprel_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "default": 0.5
        },
        "max_output_json_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 10485760
        },
        "max_input_json_bytes": {
          "type": "integer",
          "minimum": 1,
          "default": 52428800
        },
        "max_json_depth": {
          "type": "integer",
          "minimum": 1,
          "default": 200
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enable_structural": {
          "type": "boolean",
          "default": true
        },
        "enable_dependency": {
          "type": "boolean",
          "default": true
        },
        "enable_morphology": {
          "type": "boolean",
          "default": true
        },
        "enable_sentence": {
          "type": "boolean",
          "default": true
        },
        "enable_distribution": {
          "type": "boolean",
          "default": true
        },
        "enable_entity": {
          "type": "boolean",
          "default": true
        },
        "validate_text_slices": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "include_debug": {
      "type": "boolean",
      "default": false
    },
    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        },
        "level": {
          "enum": [
            "debug",
            "info",
            "warning",
            "error"
          ],
          "default": "error"
        }
      }
    }
  },
  "description": "Partial user config override for annotation_quality_filter. All sections and nested fields are optional, but unknown fields are invalid at every depth. Defaults are applied before validation against the effective config schema."
}